{{ define "sidebar" }}
  <!-- Time‑based Builds -->
  <details class="mb-4">
    <summary class="list-group-item list-group-item-action py-1 fw-bold fs-6">
      📅 Time‑based Builds&nbsp;
    </summary>
    <div class="list-group list-group-flush ms-2 mt-0">
      <a class="list-group-item list-group-item-action"
         hx-get="builds/filter?range=today" hx-target="#main-content" hx-swap="innerHTML">
        Today
      </a>
      <a class="list-group-item list-group-item-action"
         hx-get="builds/filter?range=yesterday" hx-target="#main-content" hx-swap="innerHTML">
        Yesterday
      </a>
      <a class="list-group-item list-group-item-action"
         hx-get="builds/filter?range=this_week" hx-target="#main-content" hx-swap="innerHTML">
        This Week
      </a>
      <a class="list-group-item list-group-item-action"
         hx-get="builds/filter?range=previous_week" hx-target="#main-content" hx-swap="innerHTML">
        Previous Week
      </a>
      <a class="list-group-item list-group-item-action"
         hx-get="builds/filter?range=previous_month" hx-target="#main-content" hx-swap="innerHTML">
        Previous Month
      </a>
      <a class="list-group-item list-group-item-action"
         hx-get="builds/filter?range=this_month" hx-target="#main-content" hx-swap="#main-content">
        This Month
      </a>
    </div>
  </details>

  <!-- Custom Date Filter -->
  <details class="mb-4">
    <summary class="list-group-item list-group-item-action py-2 fw-bold fs-6">
      📆 Custom Date Filter&nbsp;
    </summary>
    <div class="p-2 border rounded ms-2 mt-1">
      <form id="date-filter-form" hx-get="builds/filter" hx-target="#main-content" hx-swap="innerHTML">
        <div class="mb-0">
          <label for="from" class="form-label fw-normal mt-1" style="font-size: 0.8rem;">FROM:</label>
          <input type="date" id="from" name="from" class="form-control mb-2" required>
        </div>
        <div class="mb-0">
          <label for="to" class="form-label fw-normal" style="font-size: 0.8rem;">TO:</label>
          <input type="date" id="to" name="to" class="form-control mb-2" required>
        </div>
        <button type="submit" class="btn btn-sm btn-primary">Apply</button>
      </form>
    </div>
  </details>

  <!-- Builds by Folder -->
  <details class="mb-4">
    <summary class="list-group-item list-group-item-action py-2 fw-bold fs-6">
      🗂️ Builds by Folder&nbsp;
    </summary>
    <div class="list-group list-group-flush ms-2 mt-1">
      <a class="list-group-item list-group-item-action mb-1"
         hx-get="builds/folder" hx-target="#main-content" hx-swap="innerHTML">
        View by Folder
      </a>
    </div>
  </details>

  <!-- Search Builds -->
  <details class="mb-4">
    <summary class="list-group-item list-group-item-action py-2 fw-bold fs-6">
      🔍 Search Builds&nbsp;
    </summary>
    <div class="p-2 border rounded ms-2 mt-1">
      <div class="mb-2">
        <label for="search_by" class="form-label fw-normal" style="font-size:0.8rem;">Field:</label>
        <select id="search_by" name="search_by" class="form-select form-select-sm">
         <option value="">— select —</option>
         <option value="env">Env</option>
         <option value="project_path">Project</option>
         <option value="user_id">User</option>
       </select>
     </div>
     <div class="mb-2">
       <label for="search_term" class="form-label fw-normal" style="font-size:0.8rem;">Value:</label>
      <input id="search_term" name="search_term" type="text" class="form-control form-control-sm" placeholder="enter search term…">
     </div>
     <button type="button"
            hx-get="builds/filter?page=1&limit=35"
            hx-include="#search_by,#search_term"
            hx-target="#main-content" hx-swap="innerHTML" class="btn btn-sm btn-primary w-100">
       Search
     </button>
   </div>
  </details>
{{ end }}  
